generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// USERS & ROLES
// ============================================

enum Role {
  SUPER_ADMIN
  ADMIN
  CEO
  TEAM_MEMBER
  BUSINESS_PARTNER
  PARTNER_MANAGER
  CLIENT
  CLIENT_MANAGER
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  password        String
  role            Role      @default(TEAM_MEMBER)
  image           String?
  timezone        String    @default("Asia/Dhaka")
  // Client-side users (CLIENT / CLIENT_MANAGER) link to a Client company
  clientId        String?
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  // Worker payout info (set by the worker in their profile)
  payoutMethod    String?
  payoutDetails   String?
  withdrawBlockedUntil DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorMethod  String    @default("EMAIL")
  twoFactorCode    String?
  twoFactorCodeExp DateTime?
  totpSecret       String?
  // Cached money (ledger = WorkerTxn)
  balance         Decimal   @default(0) @db.Decimal(12, 2)
  reserve         Decimal   @default(0) @db.Decimal(12, 2)
  // First-login terms acceptance
  termsAcceptedAt DateTime?
  termsVersion    String?

  // Public registration profile
  phone      String?
  address    String?
  dateOfBirth DateTime?
  emergencyContact String?
  bio        String?
  gender     String? // MALE | FEMALE | OTHER
  profession String? // e.g. "UI/UX Designer"
  nidUrl     String? // NID/Passport document
  nidNumber  String?
  photoUrl   String? // profile photo
  identityStatus String @default("UNVERIFIED") // UNVERIFIED | PENDING | VERIFIED | REJECTED

  // Registration approval + password reset
  accountStatus String    @default("ACTIVE") // ACTIVE | PENDING_APPROVAL | REJECTED
  resetToken    String?   @unique
  resetTokenExp DateTime?

  skills               Skill[]
  jobMemberships       JobMember[]
  workSessions         WorkSession[]
  applications         Application[]
  assignedTasks        WeeklyTask[]              @relation("TaskAssignee")
  completedTasks       WeeklyTask[]              @relation("TaskCompleter")
  assignedMilestones   Milestone[]               @relation("MilestoneAssignee")
  sentMessages         Message[]
  uploadedAttachments  Attachment[]              @relation("AttachmentUploader")
  conversations        ConversationParticipant[]
  workerTxns           WorkerTxn[]
  withdrawRequests     WithdrawRequest[]
  ratingsReceived      Rating[]                  @relation("RatedWorker")
  meetingsCreated      Meeting[]                 @relation("MeetingCreator")
  meetings             MeetingParticipant[]
  notifications        Notification[]
  paymentSubmissions   PaymentSubmission[]
  profileChangeRequests UserProfileChangeRequest[]
  profileChangeReviews  UserProfileChangeRequest[] @relation("ProfileChangeReviewer")
  supportTickets        SupportTicket[]          @relation("SupportTicketReporter")
  supportTicketsAssigned SupportTicket[]         @relation("SupportTicketAssignee")
  specialOrdersWorked  SpecialOrder[]            @relation("SpecialOrderPartner")
  specialOrdersCreated SpecialOrder[]            @relation("SpecialOrderCreator")
  specialProfiles      SpecialOrderProfile[]     @relation("SpecialOrderProfilePartner")
  defaultMarketplaces  Marketplace[]             @relation("MarketplaceDefaultPartner")
  permissions          UserPermission[]
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
}

enum ProfileChangeType {
  EMAIL
  PHONE
  PAYOUT
}

enum ProfileChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

model UserProfileChangeRequest {
  id                   String              @id @default(cuid())
  userId               String
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                 ProfileChangeType
  oldValue             String?
  newValue             String
  status               ProfileChangeStatus @default(PENDING)
  withdrawBlockedUntil DateTime
  reviewedById         String?
  reviewedBy           User?               @relation("ProfileChangeReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt           DateTime?
  note                 String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
}

model UserPermission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource  String
  canCreate Boolean  @default(false)
  canRead   Boolean  @default(true)
  canUpdate Boolean  @default(false)
  canDelete Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, resource])
  @@index([userId])
  @@index([resource])
}

model EmailOtp {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============================================
// SKILLS (admin-managed master list)
// ============================================

model Skill {
  id    String @id @default(cuid())
  name  String @unique
  users User[]
  jobs  Job[]
}

// ============================================
// CLIENTS (internal clients with portal access)
// External (Fiverr/Upwork) clients live on Job
// ============================================

model Client {
  id          String  @id @default(cuid())
  companyName String
  contactName String
  email       String  @unique
  phone       String?
  country     String?
  status      String  @default("ACTIVE")
  currency    String  @default("USD")
  timezone    String  @default("UTC")
  // Cached wallet (ledgers = ClientTxn / PointTxn)
  balance     Decimal @default(0) @db.Decimal(12, 2)
  points      Int     @default(0)

  users              User[]
  jobs               Job[]
  invoices           Invoice[]
  walletTxns         ClientTxn[]
  pointTxns          PointTxn[]
  paymentSubmissions PaymentSubmission[]
  exchangeRequests   PointExchangeRequest[]
  ratings            Rating[]
  jobRequests        JobRequest[]
  specialOrders      SpecialOrder[]
  specialProfiles    SpecialOrderProfile[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
}

// ============================================
// UNIFIED JOB (Monthly / Fixed / Hourly)
// ============================================

enum JobType {
  MONTHLY
  FIXED
  HOURLY
}

enum JobStatus {
  PENDING
  OPEN
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum PublishStatus {
  DRAFT
  PUBLISHED
}

model Job {
  id          String        @id @default(cuid())
  title       String
  description String?
  type        JobType
  status      JobStatus     @default(PENDING)
  publish     PublishStatus @default(DRAFT)

  // Internal client OR external (Fiverr/Upwork) info
  clientId        String?
  client          Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  externalSource  String?
  externalName    String?
  externalCountry String?

  // Client-side pricing (what the client sees)
  // MONTHLY: per month | FIXED: total budget | HOURLY: per hour
  clientValue    Decimal? @db.Decimal(12, 2)
  clientCurrency String   @default("USD")
  vatPercent     Decimal? @db.Decimal(5, 2)

  // Default worker payout visible before application.
  // MONTHLY: per month | FIXED: total | HOURLY: per hour
  workerValue    Decimal? @db.Decimal(12, 2)
  workerCurrency String   @default("BDT")

  // Type-specific fields
  startDate       DateTime?
  billingDay      Int?
  deadline        DateTime?
  weeklyHourLimit Int?
  pausedAt        DateTime?

  requiredSkills Skill[]
  members        JobMember[]
  weeks          Week[]
  milestones     Milestone[]
  checkItems     CheckItem[]
  workSessions   WorkSession[]
  conversation   Conversation?
  applications   Application[]
  invoices       Invoice[]
  attachments    Attachment[]
  ratings        Rating[]
  extensions     ExtensionRequest[]
  meetings       Meeting[]
  workerTxns     WorkerTxn[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

// Assignment + per-worker payment (worker value)
// MONTHLY: per month | FIXED: total | HOURLY: per hour
model JobMember {
  id             String   @id @default(cuid())
  jobId          String
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workerValue    Decimal  @default(0) @db.Decimal(12, 2)
  workerCurrency String   @default("BDT")
  createdAt      DateTime @default(now())

  @@unique([jobId, userId])
}

// ============================================
// MONTHLY: WEEKS + TASKS + TEMPLATES
// ============================================

enum TaskStatus {
  PENDING
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Week {
  id         String       @id @default(cuid())
  jobId      String
  job        Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  weekNumber Int
  startDate  DateTime
  endDate    DateTime
  tasks      WeeklyTask[]

  @@unique([jobId, weekNumber])
}

model WeeklyTask {
  id            String       @id @default(cuid())
  weekId        String
  week          Week         @relation(fields: [weekId], references: [id], onDelete: Cascade)
  title         String
  priority      Priority     @default(MEDIUM)
  status        TaskStatus   @default(PENDING)
  sortOrder     Int          @default(0)
  assigneeId    String?
  assignee      User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  completedById String?
  completedBy   User?        @relation("TaskCompleter", fields: [completedById], references: [id])
  completedAt   DateTime?
  attachments   Attachment[]
  createdAt     DateTime     @default(now())
}

model CommonTask {
  id        String   @id @default(cuid())
  title     String
  priority  Priority @default(MEDIUM)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// ============================================
// FIXED: MILESTONES + CHECK ITEMS
// ============================================

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Milestone {
  id          String          @id @default(cuid())
  jobId       String
  job         Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  title       String
  description String?
  deadline    DateTime?
  charge      Decimal?        @db.Decimal(12, 2)
  status      MilestoneStatus @default(PENDING)
  sortOrder   Int             @default(0)
  assigneeId  String?
  assignee    User?           @relation("MilestoneAssignee", fields: [assigneeId], references: [id])
  completedAt DateTime?
  attachments Attachment[]
  createdAt   DateTime        @default(now())
}

model CheckItem {
  id        String  @id @default(cuid())
  jobId     String
  job       Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean @default(false)
  sortOrder Int     @default(0)
}

// ============================================
// HOURLY: WORK SESSIONS
// ============================================

model WorkSession {
  id          String       @id @default(cuid())
  jobId       String
  job         Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt   DateTime     @default(now())
  endedAt     DateTime?
  duration    Int?
  note        String?
  attachments Attachment[]
  createdAt   DateTime     @default(now())
}

// ============================================
// MARKETPLACE APPLICATIONS
// ============================================

enum ApplicationStatus {
  PENDING
  APPROVED
  DECLINED
  WITHDRAWN
}

model Application {
  id               String            @id @default(cuid())
  jobId            String
  job              Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  message          String?
  deliveryEstimate String?
  status           ApplicationStatus @default(PENDING)
  createdAt        DateTime          @default(now())

  @@unique([jobId, userId])
}

// ============================================
// CHAT (job discussions + direct messages)
// ============================================

model Conversation {
  id                    String                    @id @default(cuid())
  jobId                 String?                   @unique
  job                   Job?                      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  specialOrderClientId  String?                   @unique
  specialOrderClient    SpecialOrder?             @relation("SpecialOrderClientConversation", fields: [specialOrderClientId], references: [id], onDelete: Cascade)
  specialOrderPartnerId String?                   @unique
  specialOrderPartner   SpecialOrder?             @relation("SpecialOrderPartnerConversation", fields: [specialOrderPartnerId], references: [id], onDelete: Cascade)
  isDirect              Boolean                   @default(false)
  participants          ConversationParticipant[]
  messages              Message[]
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @default(now()) @updatedAt
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSeenAt     DateTime?

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  body           String
  seenAt         DateTime?
  pinned         Boolean      @default(false)
  pinnedAt       DateTime?
  attachments    Attachment[]
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([conversationId, pinned])
}

// ============================================
// ATTACHMENTS (files/images/video)
// ============================================

model Attachment {
  id                  String             @id @default(cuid())
  url                 String
  name                String
  size                Int?
  mimeType            String?
  uploadedById        String?
  uploadedBy          User?              @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  jobId               String?
  job                 Job?               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  messageId           String?
  message             Message?           @relation(fields: [messageId], references: [id], onDelete: SetNull)
  milestoneId         String?
  milestone           Milestone?         @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  taskId              String?
  task                WeeklyTask?        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  workSessionId       String?
  workSession         WorkSession?       @relation(fields: [workSessionId], references: [id], onDelete: Cascade)
  paymentSubmissionId String?
  paymentSubmission   PaymentSubmission? @relation(fields: [paymentSubmissionId], references: [id], onDelete: SetNull)
  specialOrderId      String?
  specialOrder        SpecialOrder?      @relation(fields: [specialOrderId], references: [id], onDelete: Cascade)
  createdAt           DateTime           @default(now())

  @@index([uploadedById])
  @@index([jobId])
  @@index([messageId])
  @@index([milestoneId])
  @@index([taskId])
  @@index([workSessionId])
  @@index([paymentSubmissionId])
  @@index([specialOrderId])
}

// ============================================
// INVOICES (auto + custom, partial, VAT)
// ============================================

enum InvoiceType {
  AUTO
  CUSTOM
  SPECIAL_ORDER
}

enum InvoiceStatus {
  DUE
  PARTIALLY_PAID
  PAYMENT_SUBMITTED
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id                         String              @id @default(cuid())
  number                     String              @unique
  type                       InvoiceType         @default(AUTO)
  title                      String?
  jobId                      String?
  job                        Job?                @relation(fields: [jobId], references: [id], onDelete: SetNull)
  specialOrderId             String?             @unique
  specialOrder               SpecialOrder?       @relation(fields: [specialOrderId], references: [id], onDelete: SetNull)
  clientId                   String
  client                     Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount                     Decimal             @db.Decimal(12, 2)
  currency                   String              @default("USD")
  vatPercent                 Decimal?            @db.Decimal(5, 2)
  balanceApplied             Decimal             @default(0) @db.Decimal(12, 2)
  amountPaid                 Decimal             @default(0) @db.Decimal(12, 2)
  status                     InvoiceStatus       @default(DUE)
  periodStart                DateTime?
  periodEnd                  DateTime?
  dueDate                    DateTime
  paymentNote                String?
  submittedAt                DateTime?
  approvedById               String?
  paidVia                    String?
  payoneerInvoiceUrl         String?
  payoneerInvoiceButtonLabel String?
  payoneerInvoiceNote        String?
  items                      InvoiceItem[]
  paymentMethods             PaymentMethod[]
  paymentSubmissions         PaymentSubmission[]
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  @@unique([jobId, periodStart])
}

enum SpecialOrderStatus {
  PLANNED
  ACTIVE
  DELIVERED
  COMPLETED
  CANCELLED
}

enum SpecialOrderReviewStatus {
  PENDING
  DONE
}

model SpecialOrder {
  id                    String                   @id @default(cuid())
  title                 String
  profileId             String?
  profile               SpecialOrderProfile?     @relation(fields: [profileId], references: [id], onDelete: SetNull)
  marketplaceId         String?
  marketplace           Marketplace?             @relation(fields: [marketplaceId], references: [id], onDelete: SetNull)
  profileName           String?
  buyerProfile          String?
  niche                 String?
  conversationSheetUrl  String?
  orderDate             DateTime?
  plannedDate           DateTime?
  dueDate               DateTime?
  deliveryDate          DateTime?
  orderAmountUsd        Decimal                  @db.Decimal(12, 2)
  clientUsdRate         Decimal                  @db.Decimal(12, 2)
  partnerUsdRate        Decimal                  @db.Decimal(12, 2)
  clientAmountBdt       Decimal                  @db.Decimal(12, 2)
  partnerCostBdt        Decimal                  @db.Decimal(12, 2)
  profitBdt             Decimal                  @db.Decimal(12, 2)
  status                SpecialOrderStatus       @default(PLANNED)
  activeState           String?
  gigImageUrl           String?
  keyword               String?
  profileLevel          String?
  reviewStatus          SpecialOrderReviewStatus @default(PENDING)
  privateFeedbackUrl    String?
  privateFeedbackDevice String?
  privateFeedbackDate   DateTime?
  privateFeedback       String?
  reviewText            String?
  adminReviewText       String?
  partnerReviewText     String?
  reviewUrl             String?
  clientComment         String?
  partnerComment        String?
  deliveryNote          String?
  conversationMessages  Json?
  conversationFields    Json?
  clientId              String
  client                Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  partnerId             String?
  partner               User?                    @relation("SpecialOrderPartner", fields: [partnerId], references: [id], onDelete: SetNull)
  createdById           String?
  createdBy             User?                    @relation("SpecialOrderCreator", fields: [createdById], references: [id], onDelete: SetNull)
  invoice               Invoice?
  earning               Earning?
  clientConversation    Conversation?            @relation("SpecialOrderClientConversation")
  partnerConversation   Conversation?            @relation("SpecialOrderPartnerConversation")
  attachments           Attachment[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([clientId])
  @@index([partnerId])
  @@index([profileId])
  @@index([marketplaceId])
  @@index([status])
  @@index([plannedDate])
}

model Marketplace {
  id             String                  @id @default(cuid())
  name           String                  @unique
  active         Boolean                 @default(true)
  clientUsdRate  Decimal                 @default(125) @db.Decimal(12, 2)
  partnerUsdRate Decimal                 @default(115) @db.Decimal(12, 2)
  defaultPartnerId String?
  defaultPartner   User?                   @relation("MarketplaceDefaultPartner", fields: [defaultPartnerId], references: [id], onDelete: SetNull)
  profiles       SpecialOrderProfile[]
  specialOrders  SpecialOrder[]
  rateTiers      MarketplaceRateTier[]
  adjustments    MarketplaceAdjustment[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([defaultPartnerId])
}

model MarketplaceRateTier {
  id             String      @id @default(cuid())
  marketplaceId  String
  marketplace    Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)
  minUsd         Decimal     @default(0) @db.Decimal(12, 2)
  maxUsd         Decimal?    @db.Decimal(12, 2)
  clientUsdRate  Decimal     @db.Decimal(12, 2)
  partnerUsdRate Decimal     @db.Decimal(12, 2)
  active         Boolean     @default(true)
  priority       Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([marketplaceId])
  @@index([active, priority])
}

model MarketplaceAdjustment {
  id            String      @id @default(cuid())
  marketplaceId String
  marketplace   Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)
  label         String
  type          String
  thresholdUsd  Decimal?    @db.Decimal(12, 2)
  value         Decimal     @db.Decimal(12, 2)
  active        Boolean     @default(true)
  priority      Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([marketplaceId])
  @@index([active, priority])
}

model SpecialOrderProfile {
  id              String         @id @default(cuid())
  clientId        String?
  client          Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  partnerId       String?
  partner         User?          @relation("SpecialOrderProfilePartner", fields: [partnerId], references: [id], onDelete: SetNull)
  marketplaceId   String
  marketplace     Marketplace    @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)
  profileName     String
  profileLevel    String?
  niche           String?
  keywords        String?
  gigThumbnailUrl String?
  active          Boolean        @default(true)
  note            String?
  orders          SpecialOrder[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([clientId])
  @@index([partnerId])
  @@index([marketplaceId])
  @@index([active])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  qty         Int     @default(1)
  amount      Decimal @db.Decimal(12, 2)
}

model PaymentMethod {
  id                    String               @id @default(cuid())
  key                   String?              @unique
  label                 String
  details               String
  active                Boolean              @default(true)
  instructions          String?
  warning               String?
  sortOrder             Int                  @default(0)
  receiverNumber        String?
  accountType           String?
  wiseEmail             String?
  wiseAccountName       String?
  wisePaymentUrl        String?
  wiseTransferDetails   String?
  cashReceiverInfo      String?
  payoneerDirectEnabled Boolean              @default(false)
  payoneerMode          String?
  payoneerMerchantId    String?
  payoneerButtonLabel   String?
  invoices              Invoice[]
  bankAccounts          BankPaymentAccount[]
  submissions           PaymentSubmission[]
}

model BankPaymentAccount {
  id              String              @id @default(cuid())
  paymentMethodId String
  paymentMethod   PaymentMethod       @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  bankName        String
  accountName     String
  accountNumber   String
  branchName      String?
  routingNumber   String?
  swiftCode       String?
  currency        String              @default("USD")
  instructions    String?
  active          Boolean             @default(true)
  sortOrder       Int                 @default(0)
  submissions     PaymentSubmission[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([paymentMethodId])
}

model PaymentSubmission {
  id                    String              @id @default(cuid())
  invoiceId             String
  invoice               Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  clientId              String
  client                Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  paymentMethodId       String?
  paymentMethod         PaymentMethod?      @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  methodKey             String
  methodLabel           String
  amount                Decimal             @db.Decimal(12, 2)
  currency              String              @default("USD")
  paymentDate           DateTime
  selectedBankAccountId String?
  selectedBankAccount   BankPaymentAccount? @relation(fields: [selectedBankAccountId], references: [id], onDelete: SetNull)
  transactionId         String?
  secondaryReference    String?
  senderNumber          String?
  senderEmail           String?
  senderName            String?
  senderBankName        String?
  senderBankAccount     String?
  cardLast4             String?
  paymentSource         String?
  receiverName          String?
  note                  String?
  status                String              @default("PENDING")
  attachments           Attachment[]
  submittedById         String?
  submittedBy           User?               @relation(fields: [submittedById], references: [id], onDelete: SetNull)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([invoiceId])
  @@index([clientId])
  @@index([paymentMethodId])
  @@index([selectedBankAccountId])
  @@index([submittedById])
}

// ============================================
// CLIENT WALLET & LOYALTY
// ============================================

enum ClientTxnKind {
  INVOICE_PAYMENT
  ADVANCE
  ADJUSTMENT
  POINT_EXCHANGE
  INVOICE_DEDUCT
  REFUND
}

model ClientTxn {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount      Decimal       @db.Decimal(12, 2)
  kind        ClientTxnKind
  note        String?
  invoiceId   String?
  createdById String?
  createdAt   DateTime      @default(now())
}

enum PointTxnKind {
  EARN
  EXCHANGE
  ADJUST
}

model PointTxn {
  id        String       @id @default(cuid())
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  points    Int
  kind      PointTxnKind
  note      String?
  invoiceId String?
  createdAt DateTime     @default(now())
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model PointExchangeRequest {
  id            String        @id @default(cuid())
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  points        Int
  status        RequestStatus @default(PENDING)
  processedById String?
  createdAt     DateTime      @default(now())
  processedAt   DateTime?
}

// ============================================
// WORKER MONEY (balance + 10% reserve)
// ============================================

enum WorkerBucket {
  BALANCE
  RESERVE
}

enum WorkerTxnKind {
  JOB_PAYOUT
  MONTHLY_CREDIT
  HOURLY_CREDIT
  RESERVE_HOLD
  RESERVE_RELEASE
  WITHDRAWAL
  ADJUSTMENT
  PENALTY
}

model WorkerTxn {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal       @db.Decimal(12, 2)
  bucket      WorkerBucket  @default(BALANCE)
  kind        WorkerTxnKind
  jobId       String?
  job         Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  note        String?
  createdById String?
  createdAt   DateTime      @default(now())
}

enum WithdrawStatus {
  PENDING
  PAID
  REJECTED
}

model WithdrawRequest {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Decimal        @db.Decimal(12, 2)
  method        String
  details       String
  fromReserve   Boolean        @default(false)
  status        WithdrawStatus @default(PENDING)
  reference     String?
  processedById String?
  createdAt     DateTime       @default(now())
  processedAt   DateTime?
}

// ============================================
// ACCOUNTING (earnings / expenses / rates)
// ============================================

enum EntrySource {
  AUTO
  CUSTOM
}

model Earning {
  id             String        @id @default(cuid())
  title          String
  description    String?
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("BDT")
  amountBdt      Decimal       @db.Decimal(12, 2)
  source         EntrySource   @default(CUSTOM)
  category       String        @default("Other")
  status         String        @default("POSTED")
  invoiceId      String?       @unique
  specialOrderId String?       @unique
  specialOrder   SpecialOrder? @relation(fields: [specialOrderId], references: [id], onDelete: SetNull)
  createdById    String?
  createdAt      DateTime      @default(now())

  @@index([specialOrderId])
}

model Expense {
  id           String      @id @default(cuid())
  title        String
  description  String?
  amount       Decimal     @db.Decimal(12, 2)
  currency     String      @default("BDT")
  amountBdt    Decimal     @db.Decimal(12, 2)
  category     String      @default("Other")
  source       EntrySource @default(CUSTOM)
  recurring    Boolean     @default(false)
  recurringDay Int?
  createdById  String?
  createdAt    DateTime    @default(now())
}

model ExchangeRate {
  code      String   @id
  rateToBdt Decimal  @db.Decimal(12, 4)
  updatedAt DateTime @updatedAt
}

// Key-value settings: loyalty rules, terms text, company info
model Setting {
  key   String @id
  value String
}

// ============================================
// PUBLIC LANDING PAGE CMS
// ============================================

model LandingHeroSlide {
  id             String   @id @default(cuid())
  badge          String?
  title          String
  description    String
  imageUrl       String?
  primaryLabel   String?
  primaryTarget  String?
  secondaryLabel String?
  secondaryTarget String?
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LandingServiceCategory {
  id        String           @id @default(cuid())
  name      String
  slug      String           @unique
  sortOrder Int              @default(0)
  active    Boolean          @default(true)
  services  LandingService[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model LandingService {
  id          String                 @id @default(cuid())
  categoryId  String?
  category    LandingServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title       String
  description String
  details     String?
  icon        String?
  imageUrl    String?
  sortOrder   Int                    @default(0)
  active      Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
}

model LandingProject {
  id          String   @id @default(cuid())
  title       String
  category    String?
  description String
  details     String?
  imageUrl    String?
  projectUrl  String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LandingTeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String
  bio         String?
  photoUrl    String?
  skills      Json?
  socialLinks Json?
  jobs        Json?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LandingReview {
  id         String   @id @default(cuid())
  clientName String
  clientRole String?
  company    String?
  avatarUrl  String?
  rating     Int      @default(5)
  quote      String
  details    String?
  verified   Boolean  @default(true)
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LandingPageContent {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model LandingContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}

model LandingChatLead {
  id        String               @id @default(cuid())
  name      String
  email     String
  subject   String
  status    String               @default("OPEN")
  messages  LandingChatMessage[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model LandingChatMessage {
  id        String          @id @default(cuid())
  leadId    String
  lead      LandingChatLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sender    String          @default("GUEST")
  body      String
  createdAt DateTime        @default(now())
}

// ============================================
// LEAD COLLECTIONS + FOLLOW-UP CRM
// ============================================

enum LeadStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  QUALIFIED
  PROPOSAL
  WON
  LOST
  ARCHIVED
}

enum LeadSource {
  MANUAL
  WEBSITE
  IMPORT
  FACEBOOK
  LINKEDIN
  FIVERR
  UPWORK
  OTHER
}

enum LeadActivityType {
  NOTE
  EMAIL
  CALL
  FOLLOW_UP
  STATUS_CHANGE
  IMPORT
}

model LeadCollection {
  id          String   @id @default(cuid())
  name        String
  description String?
  active      Boolean  @default(true)
  leads       Lead[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id             String         @id @default(cuid())
  collectionId   String?
  collection     LeadCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  name           String
  company        String?
  email          String?
  phone          String?
  source         LeadSource      @default(MANUAL)
  status         LeadStatus      @default(NEW)
  value          Decimal?        @db.Decimal(12, 2)
  currency       String          @default("USD")
  tags           String?
  notes          String?
  nextFollowUpAt DateTime?
  lastContactedAt DateTime?
  createdById    String?
  activities     LeadActivity[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([collectionId])
  @@index([status])
  @@index([source])
  @@index([nextFollowUpAt])
}

model LeadActivity {
  id            String           @id @default(cuid())
  leadId        String
  lead          Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type          LeadActivityType
  subject       String?
  body          String
  status        String           @default("DONE")
  scheduledAt   DateTime?
  completedAt   DateTime?
  createdById   String?
  createdAt     DateTime         @default(now())

  @@index([leadId])
  @@index([type])
  @@index([scheduledAt])
}

// ============================================
// BUG REPORTS + FEEDBACK
// ============================================

model SupportTicket {
  id           String   @id @default(cuid())
  type         String   @default("FEEDBACK") // BUG | FEEDBACK | FEATURE | OTHER
  priority     String   @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  status       String   @default("OPEN") // OPEN | REVIEWING | PLANNED | RESOLVED | CLOSED
  title        String
  description  String
  pageUrl      String?
  screenshotUrl String?
  reporterId   String
  reporter     User     @relation("SupportTicketReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo   User?    @relation("SupportTicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  adminNote    String?
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([reporterId])
  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([createdAt])
}

// ============================================
// CLIENT JOB REQUESTS
// ============================================

model JobRequest {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String
  budgetHint  String?
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())
}

// ============================================
// MEETINGS (Jitsi, admin approval)
// ============================================

enum MeetingStatus {
  PENDING_APPROVAL
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Meeting {
  id           String               @id @default(cuid())
  title        String
  scheduledAt  DateTime
  roomCode     String               @unique @default(cuid())
  status       MeetingStatus        @default(PENDING_APPROVAL)
  jobId        String?
  job          Job?                 @relation(fields: [jobId], references: [id], onDelete: SetNull)
  createdById  String
  createdBy    User                 @relation("MeetingCreator", fields: [createdById], references: [id])
  participants MeetingParticipant[]
  createdAt    DateTime             @default(now())
}

model MeetingParticipant {
  id        String  @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

// ============================================
// RATINGS + EXTENSIONS + NOTIFICATIONS + AUDIT
// ============================================

model Rating {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerId  String
  worker    User     @relation("RatedWorker", fields: [workerId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  stars     Int
  review    String?
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([jobId, workerId])
}

model ExtensionRequest {
  id            String        @id @default(cuid())
  jobId         String
  job           Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  milestoneId   String?
  requestedById String
  newDate       DateTime
  reason        String?
  status        RequestStatus @default(PENDING)
  processedById String?
  createdAt     DateTime      @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String?
  entityId  String?
  meta      String?
  createdAt DateTime @default(now())
}
